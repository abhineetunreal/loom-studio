// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // In Prisma 7, connection URLs are not set here.
  // - Migrations use the URL in prisma.config.ts (DIRECT_URL — direct pg connection)
  // - Runtime queries use a driver adapter in lib/db.ts (DATABASE_URL — pooler)
}

model Tenant {
  id           String   @id @default(cuid())
  slug         String   @unique // used in subdomain: slug.loomstudio.com
  name         String   // internal name e.g. "Carpets Bazaar"
  displayName  String?  // public-facing brand name shown in the UI
  logoUrl      String?  // URL to brand logo; replaces "Loom Studio" text when set
  faviconUrl   String?  // URL to brand favicon
  primaryColor String   @default("#1a1612")
  accentColor  String?  // secondary brand color
  domain       String?  @unique // custom domain for white-label routing
  adminEmail   String
  ssoSecret    String?  // shared secret for SSO token verification
  websiteUrl   String?  // brand's main website URL for product linking
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  designs          Design[]
  yarns            YarnColor[]
  users            TenantUser[]
  submissions      ColorwaySubmission[]
  collections      Collection[]
  savedColorways   SavedColorway[]
  colorwayFolders  ColorwayFolder[]
  colorLookups     ColorLookup[]
}

model TenantUser {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  email      String
  name       String?
  role       UserRole @default(PENDING)
  authUserId String? // Supabase Auth user ID
  provider   String? // "google" | "magic_link" | "password"
  canUpload  Boolean  @default(false)
  createdAt  DateTime @default(now())

  collectionAccess CollectionAccess[]
  uploadedDesigns  Design[]
  savedColorways   SavedColorway[]
  colorwayFolders  ColorwayFolder[]

  @@unique([tenantId, email])
}

enum UserRole {
  PENDING  // just signed up, waiting for approval
  APPROVED // can access full catalog
  DEMO     // limited access, sample designs only
  ADMIN    // can manage designs, approve users; cannot touch ADMIN/OWNER rows
  OWNER    // highest tier; can promote/demote ADMIN; cannot be modified by non-self
}

// A rug design in the catalog
model Design {
  id           String   @id @default(cuid())
  tenantId     String? // nullable — existing rows don't break
  tenant       Tenant?  @relation(fields: [tenantId], references: [id])
  name         String
  slug         String   @unique
  imageUrl     String // web-ready PNG (converted from BMP at seed time)
  sourceBmpUrl String // original BMP — canonical production file
  width        Int
  height       Int
  // JSON array of PaletteEntry: { index, hex, pixelCount, percentage }
  // Stored as-is from the BMP; never snapped to the yarn library
  palette      Json
  collectionId  String? // FK to Collection — replaces the old collection TEXT column
  collection    Collection? @relation(fields: [collectionId], references: [id])
  uploadedById  String?
  uploadedBy    TenantUser? @relation(fields: [uploadedById], references: [id])
  isHidden      Boolean     @default(false) // hide from users within an accessible collection
  isActive     Boolean     @default(true)
  isDemo       Boolean     @default(false) // DEMO tier users only see isDemo designs
  externalSku  String?     // SKU matching the website's product catalog
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  submissions    ColorwaySubmission[]
  savedColorways SavedColorway[]

  @@unique([tenantId, externalSku])
}

model Collection {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  slug      String
  parentId  String? // for nested folders later
  parent    Collection?  @relation("CollectionTree", fields: [parentId], references: [id])
  children  Collection[] @relation("CollectionTree")
  designs   Design[]
  access    CollectionAccess[]
  createdAt DateTime @default(now())

  @@unique([tenantId, slug])
}

model CollectionAccess {
  id           String     @id @default(cuid())
  tenantUserId String
  tenantUser   TenantUser @relation(fields: [tenantUserId], references: [id], onDelete: Cascade)
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([tenantUserId, collectionId])
}

// A yarn from the physical yarn library (scoped per tenant)
// @@map keeps the underlying DB table named "Yarn" so no data is lost on migration
model YarnColor {
  id             String   @id @default(cuid())
  tenantId       String? // nullable — existing rows don't break
  tenant         Tenant?  @relation(fields: [tenantId], references: [id])
  code           String
  name           String
  hex            String // authoritative display color
  material       String?
  pileType       String?
  swatchImageUrl String? // reserved for v1.5 — falls back to hex swatch when null
  renderType     String  @default("shader")  // "shader" | "photo"
  textureKpsi    Int?
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)

  submissionMappings SubmissionColorMapping[]

  @@unique([tenantId, code])
  @@map("Yarn")
}

// A customer's colorway request
model ColorwaySubmission {
  id            String   @id @default(cuid())
  tenantId      String? // nullable — existing rows don't break
  tenant        Tenant?  @relation(fields: [tenantId], references: [id])
  designId      String
  design        Design   @relation(fields: [designId], references: [id])
  customerName  String
  customerEmail String
  notes         String?
  snapshotUrl   String? // flattened PNG in Supabase Storage — convenience preview
  createdAt     DateTime @default(now())

  colorMappings SubmissionColorMapping[]
}

// Maps one original design color → one yarn for a given submission
model SubmissionColorMapping {
  id           String             @id @default(cuid())
  submissionId String
  submission   ColorwaySubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  originalHex  String // the design's original palette color
  percentage   Float // what % of the design this color covers
  yarnId       String
  yarn         YarnColor          @relation(fields: [yarnId], references: [id])
}

// Rendered-hex → yarn code lookup (one per tenant, seeded from JSON)
model ColorLookup {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  renderedHex String   // hex key from the design BMP/CTF, e.g. "#002453"
  yarnCode    String   // OneLoom code, e.g. "OU 49"
  catalogHex  String?  // catalog swatch hex (may differ from renderedHex)
  library     String   @default("OneLoom")
  createdAt   DateTime @default(now())

  @@unique([tenantId, renderedHex])
}

// A user's saved colorway for a design — multiple saves per user per design allowed
model SavedColorway {
  id           String          @id @default(cuid())
  designId     String
  design       Design          @relation(fields: [designId], references: [id])
  userId       String
  user         TenantUser      @relation(fields: [userId], references: [id])
  tenantId     String
  tenant       Tenant          @relation(fields: [tenantId], references: [id])
  name         String          @default("Untitled")
  userEmail    String?         // denormalized for admin queries
  // Legacy: { [paletteIndex]: { yarnId, yarnCode, yarnHex, libraryName } }
  colorMapping Json
  // New format: { globalMap: Record<hex, {hex,yarnCode,yarnId}>, regionFills: [{seedX,seedY,originalColor,newHex,newYarnCode,newYarnId}] }
  operations   Json?
  folderId     String?
  folder       ColorwayFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  snapshotUrl  String?         // Supabase storage URL for canvas PNG export
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

// Folder for organizing saved colorways (per user, per tenant)
model ColorwayFolder {
  id        String          @id @default(cuid())
  tenantId  String
  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  userId    String
  user      TenantUser      @relation(fields: [userId], references: [id])
  name      String
  createdAt DateTime        @default(now())

  colorways SavedColorway[]

  @@unique([userId, name])
}
